# HistoryChat RAG – Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości

# Czat RAG: ustaw OPENAI_API_KEY (pierwszeństwo) lub GEMINI_API_KEY
OPENAI_API_KEY=your_openai_api_key_here
# Opcjonalnie inny model czatu (domyślnie gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o

# Alternatywa: Gemini zamiast OpenAI (tylko jeśli brak OPENAI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key_here

# Port backendu (domyślnie 8000)
BACKEND_PORT=8000

# Frontend (Vite): zwykle NIE ustawiaj — wtedy /api i /avatars idą przez proxy na ten sam host co strona
# (działa też przy wejściu z sieci LAN, np. http://192.168.x.x:3001). Ustaw tylko gdy API jest osobną domeną.
# VITE_API_URL=http://localhost:8000
# Gdy backend ma API_AUTH_ENABLED=true — ustaw ten sam sekret co HISTORYCHAT_API_KEY (Bearer na /api/chat, /api/tts, /api/generate-avatar)
# VITE_API_KEY=your_same_api_key_as_backend

# Opcjonalnie: wersja zwracana przez GET /api/health (np. przy wdrożeniu)
# APP_VERSION=1.0.0

# Produkcja: CORS (lista originów rozdzielana przecinkami). Jeśli puste/nieustawione — backend pozwala na wszystkie originy (dev).
# Przykład: CORS_ORIGINS=http://localhost:3000,https://twoja-domena.pl
# CORS_ORIGINS=

# Produkcja: rate limiting (domyślnie per-IP; przy API_AUTH_ENABLED klucz z nagłówka Bearer jest preferowany).
# Wiele workerów / instancji: ustaw współdzielony backend (Redis), np.:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CHAT=60 per minute
# RATE_LIMIT_TTS=30 per minute
# RATE_LIMIT_AVATAR=10 per minute

# Enterprise: wymuszony klucz API na kosztownych endpointach (POST /api/chat, /api/tts, /api/generate-avatar)
# API_AUTH_ENABLED=false
# Jeden klucz:
# HISTORYCHAT_API_KEY=your_long_random_secret
# Wiele kluczy (rozdzielone przecinkami):
# HISTORYCHAT_API_KEYS=key_for_portal,key_for_mobile

# Dzienny limit żądań na kosztowne endpointy (UTC), per klucz API lub per IP gdy auth wyłączone (zob. API_BUDGET_WITHOUT_AUTH).
# Wymaga REDIS_URL dla spójności między instancjami (bez Redis — licznik tylko w pamięci procesu).
# API_DAILY_REQUEST_BUDGET=10000
# REDIS_URL=redis://localhost:6379/1
# API_BUDGET_WITHOUT_AUTH=true

# Metryki Prometheus (text/plain). Gdy wyłączone — GET /api/metrics zwraca 404.
# METRICS_ENABLED=false

# Feature flagi (true/false lub 1/0)
# Zapis rozmów do data/chat_history.jsonl (włącz świadomie; to pełna treść rozmów)
ENABLE_CHAT_HISTORY=false
# TTS = odczyt odpowiedzi głosem (OpenAI speech); bez true — brak audio po odpowiedzi.
ENABLE_TTS=false
# Portrety postaci przez OpenAI Images (DALL-E 3) — zapis do public/avatars/<id>.jpg
# Wymaga prawdziwego OPENAI_API_KEY (powyżej) i dostępu do API obrazów na koncie OpenAI.
ENABLE_AVATAR_GENERATION=false

# Retry/backoff na błędy tymczasowe (429/timeout/connection) dla LLM i TTS
LLM_RETRY_ATTEMPTS=3
TTS_RETRY_ATTEMPTS=3

# Timeout HTTP dla wywołań zewnętrznych (sekundy)
# OPENAI_HTTP_TIMEOUT=60
# GEMINI_HTTP_TIMEOUT=60
# TTS_HTTP_TIMEOUT=60
