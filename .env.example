# HistoryChat RAG – Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości

# Klucz API do Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Alternatywnie: klucz OpenAI (jeśli używasz GPT)
# OPENAI_API_KEY=your_openai_api_key_here

# Port backendu (domyślnie 8000)
BACKEND_PORT=8000
